---
interface VideoItem { youtube?: string | null; title?: string; }
interface Props { items: VideoItem[]; }
const { items } = Astro.props;
const idOf = (s: string | null | undefined) => {
  const v = (s || '').trim();
  if (!v) return '';
  const m = v.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([\w-]{11})/);
  if (m) return m[1];
  return /^[\w-]{11}$/.test(v) ? v : '';
};
const vids = (items || []).map((v) => ({ id: idOf(v.youtube), title: v.title || '' })).filter((v) => v.id);
---
{vids.length > 0 && (
  <div class="video-grid">
    {vids.map((v) => (
      <button class="video-item" data-yt={v.id} aria-label={v.title ? `Play video: ${v.title}` : 'Play video'}>
        <img class="video-thumb" src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} loading="lazy" />
        <span class="video-play" aria-hidden="true"></span>
        {v.title && <span class="video-title">{v.title}</span>}
      </button>
    ))}
  </div>
)}
