---
import { getSite } from '../lib/site';
import { SITE, SHOW_QUOTES } from '../lib/config';
import SocialIcon from './SocialIcon.astro';
const site = await getSite();
const links = site.socials.filter((s) => s.show);
const tel = "tel:" + site.phoneHref;
---
<header class="site-header" data-lat={SITE.lat} data-lng={SITE.lng} data-tz={SITE.timezone}>
  <div class="container header-inner">
    <a href="/" class="brand"><img class="brand-logo" src="/images/logo.png" alt={site.name} /></a>
    <a class="header-phone" href={tel}>📞 {site.phone}</a>
    <nav class="nav" id="site-nav">
      <a href="/#catch">What We've Got</a>
      <a href="/#about">Meet Paul</a>
      <a href="/#hours">Hours &amp; Pickup</a>
      <a href="/#faq">FAQ</a>
      <a href="/#contact">Contact</a>
      <div class="nav-follow">
        <span class="nav-follow-label">Follow Us</span>
        <div class="nav-follow-links">
          {links.map((s) => (
            <a class="social-link" data-brand={s.brand} href={s.url} target="_blank" rel="noopener" aria-label={s.name}>
              <SocialIcon brand={s.brand} icon={s.icon} /><span class="social-name">{s.name}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
    <div class="header-actions">
      <div class="header-socials">
        {links.map((s) => (
          <a class="social-link" data-brand={s.brand} href={s.url} target="_blank" rel="noopener" aria-label={s.name}>
            <SocialIcon brand={s.brand} icon={s.icon} /><span class="social-name">{s.name}</span>
          </a>
        ))}
      </div>
      <button class="theme-toggle" data-theme-toggle aria-label="Toggle dark mode">
        <span class="tt-ico tt-sun" aria-hidden="true">☀️</span><span class="tt-ico tt-moon" aria-hidden="true">🌙</span>
      </button>
      <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
