---
import Base from '../layouts/Base.astro';
import { getSite } from '../lib/site';

const site = await getSite();
const tel = "tel:" + site.phoneHref;
const sms = "sms:" + site.phoneHref;

const mapsDir = "https://www.google.com/maps/dir/?api=1&destination=1044%20W%20Rio%20Grande%20Ave%2C%20Wildwood%2C%20NJ%2008260";
const mapEmbed = "https://maps.google.com/maps?q=1044%20W%20Rio%20Grande%20Ave%2C%20Wildwood%2C%20NJ%2008260&z=15&output=embed";
const origin = Astro.site?.href ?? 'https://pfclamsandcrabs.com/';

const bizLd = {
  "@context": "https://schema.org", "@type": "LocalBusiness", "name": "PF Clams and Crabs",
  "image": origin + "images/logo.png", "telephone": "+16093053836", "email": site.email, "url": origin, "priceRange": "$$",
  "address": { "@type": "PostalAddress", "streetAddress": "1044 W Rio Grande Ave", "addressLocality": "Wildwood", "addressRegion": "NJ", "postalCode": "08260", "addressCountry": "US" },
  "geo": { "@type": "GeoCoordinates", "latitude": 38.9945679, "longitude": -74.8431244 },
  "areaServed": ["Wildwood, NJ", "Cape May County, NJ", "South Jersey Shore"]
};
const faqs = [
  ["Are the clams and crab really local?", "Yes — Paul farms the hard clams right in Cape May County waters and catches the blue crab himself. It goes straight from the dock to you, with no dealer in between."],
  ["How do I buy?", "Call or text Paul at (609) 305-3836 to reserve what you want, then pick it up at the dock — 1044 W Rio Grande Ave, Wildwood. Pay cash or card at pickup."],
  ["What do prices run?", "Prices and pack sizes change with the season and the catch, so call or text for today's availability and pricing. Paul will set you up."],
  ["Is the crab sold live?", "Yes — Jersey blue crab is sold live, by the dozen, half-bushel, or bushel, while the season's running."],
  ["Do you ship or deliver?", "Not this season — local dock pickup only for now."],
  ["When are the crabs running?", "Through the summer, when they're biting. Call ahead — when the crabs are in, they go fast."]
];
const faqLd = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(([q, a]) => ({ "@type": "Question", "name": q, "acceptedAnswer": { "@type": "Answer", "text": a } })) };
---
<Base
  title="PF Clams and Crabs — Fresh Cape May Clams & Live Jersey Blue Crab | Wildwood, NJ"
  description="Farm-raised Cape May County hard clams and hand-caught live Jersey blue crab, sold straight from the dock in Wildwood, NJ. Call or text Paul to reserve — no middleman."
  structuredData={[bizLd, faqLd]}
  skipTarget="#catch"
>

  <section class="hero" id="top">
    <div class="hero-seal">Fresh · Cape May County · Local · NJ</div>
    <div class="container hero-inner" style="grid-template-columns:1fr;max-width:780px;">
      <div class="hero-text">
        <span class="eyebrow">Wildwood, New Jersey</span>
        <h1>Fresh off the dock. No middleman.</h1>
        <p class="hero-sub">Farm-raised Cape May clams and live Jersey blue crab — grown and caught by Paul himself, sold straight to you off the Wildwood dock.</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={tel}>📞 Call {site.phone}</a>
          <a class="btn btn-ghost" href={sms}>💬 Text to reserve</a>
        </div>
        <p class="hero-note">Dock pickup · Cash or card · Call for today's catch &amp; price</p>
      </div>
    </div>
  </section>
  <div class="rope"></div>

  <div class="trustbar">
    <div class="container">
      <ul>
        <li><span class="check">✓</span> Farm-raised Cape May clams</li>
        <li><span class="check">✓</span> Live Jersey blue crab</li>
        <li><span class="check">✓</span> Straight from the dock</li>
        <li><span class="check">✓</span> 20 years on the water</li>
      </ul>
    </div>
  </div>

  <section class="section section-light" id="catch">
    <div class="container">
      <span class="eyebrow">Off the dock</span>
      <h2>What we've got</h2>
      <p class="section-lead">Grown and caught in Cape May County waters and pulled fresh. What's in changes with the season and the tides.</p>
      <div class="catch-grid">
        <article class="catch-card">
          <div class="ph clam"><span>photo: fresh-pulled clams</span><div class="season">Year-round</div></div>
          <div class="bd">
            <h3>Hard Clams</h3>
            <p>Farm-raised in our home waters — littlenecks for the raw bar, topnecks for the pot. Clean, briny, grit-free. By the dozen, half-bushel, or bushel.</p>
            <span class="price">Call for today's price</span>
          </div>
        </article>
        <article class="catch-card">
          <div class="ph crab"><span>photo: live blue crab</span><div class="season">In season</div></div>
          <div class="bd">
            <h3>Live Blue Crab</h3>
            <p>Jersey blue crab Paul runs his own pots for — sold live, hes or shes, by the dozen, half-bushel, or bushel, while the season's running.</p>
            <span class="price">Subject to availability</span>
          </div>
        </article>
      </div>
      <div style="margin-top:26px;background:var(--card);border:1px solid var(--border);border-left:4px solid var(--accent);border-radius:0 var(--radius) var(--radius) 0;padding:20px 24px;">
        <strong style="color:var(--text);">Prices and what's in change with the tides.</strong>
        <span style="color:var(--text-body);"> Call or text Paul for today's catch and pricing — <a href={tel} style="color:var(--link);font-weight:700;">{site.phone}</a>. Reserving for a cookout? Give him a few days' notice.</span>
      </div>
    </div>
  </section>

  <div class="rope"></div>

  <section class="section story-band" id="about">
    <div class="container welcome">
      <div class="welcome-media">
        <div style="aspect-ratio:4/3;border-radius:var(--radius);background:linear-gradient(160deg,#2a5562,#0a1b26);display:flex;align-items:flex-end;justify-content:flex-start;color:rgba(243,233,212,.6);font-style:italic;padding:14px;border:1px solid #2a4456;font-size:.8rem;">[ photo: Paul on the dock — coming soon ]</div>
      </div>
      <div class="welcome-text">
        <span class="eyebrow">The man on the dock</span>
        <blockquote>“Twenty years on these waters. Up to now it all went to dealers — this year I'm selling straight to you. Same clams, same crab, just fresher, and without the middleman taking the cut.”</blockquote>
        <cite>— Paul, PF Clams and Crabs</cite>
      </div>
    </div>
  </section>

  <section class="section section-light" id="hours">
    <div class="container">
      <span class="eyebrow">Find the dock</span>
      <h2>Hours &amp; Pickup</h2>
      <div class="hl-grid">
        <div class="hours-card">
          <h3>Hours</h3>
          <table class="hours-table"><tbody>{site.hours.map((h) => (<tr><td>{h.day}</td><td>{h.time}</td></tr>))}</tbody></table>
          <p style="color:var(--text-muted);font-size:.9rem;margin-top:14px;">Seasonal — Paul sets hours by the day. Call ahead before you come.</p>
        </div>
        <div class="location-info">
          <p class="address"><strong>{site.name}</strong><br /><span>{site.address}</span></p>
          <p><strong>Phone:</strong> <a href={tel}>{site.phone}</a><br /><strong>Email:</strong> <a href={"mailto:" + site.email}>{site.email}</a></p>
          <a class="btn btn-primary" href={mapsDir} target="_blank" rel="noopener">Get Directions</a>
          <div class="location-map" style="margin-top:18px;"><iframe title="Map to PF Clams and Crabs" loading="lazy" allowfullscreen src={mapEmbed}></iframe></div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Crabs running? Reserve a bushel.</h2>
      <p>Call or text Paul for today's catch — dock pickup in Wildwood.</p>
      <a class="btn btn-primary" href={tel}>📞 {site.phone}</a>
    </div>
  </section>

  <section class="section tband">
    <div class="container">
      <div class="qm">&ldquo;</div>
      <blockquote>Freshest clams on the island — we grabbed a bushel for the cookout and they were gone before the burgers.</blockquote>
      <span class="stamp">A Wildwood Regular</span>
      <p style="font-size:.75rem;color:var(--text-muted);margin-top:12px;">Sample — Paul's real customer quotes drop in here.</p>
    </div>
  </section>

  <section class="section section-light" id="faq">
    <div class="container faq-wrap">
      <span class="eyebrow">Questions</span>
      <h2>Frequently Asked</h2>
      {faqs.map(([q, a]) => (<details class="faq"><summary>{q}</summary><p>{a}</p></details>))}
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container contact-inner" style="text-align:center;">
      <span class="eyebrow">Get in touch</span>
      <h2>Reserve your clams &amp; crab</h2>
      <p class="section-lead" style="margin-left:auto;margin-right:auto;">Call or text Paul with what you want and when — he'll set you up for dock pickup.</p>
      <div class="hero-cta" style="justify-content:center;">
        <a class="btn btn-primary" href={tel}>📞 Call {site.phone}</a>
        <a class="btn btn-ghost" href={sms}>💬 Text to reserve</a>
      </div>
      <p class="form-note" style="margin-top:14px;">Or email <a href={"mailto:" + site.email}>{site.email}</a></p>
    </div>
  </section>

</Base>
